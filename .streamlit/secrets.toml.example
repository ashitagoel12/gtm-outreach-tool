# Copy this file to .streamlit/secrets.toml for local dev
# On Streamlit Cloud, add secrets via App Settings → Secrets
# NEVER commit secrets.toml — it is gitignored

# Required: Anthropic API key for Claude API calls
ANTHROPIC_API_KEY = "sk-ant-..."

# HubSpot tokens are entered by users directly in the app UI at runtime.
# They are password-masked, never stored server-side, and not persisted
# between sessions — so no HUBSPOT_API_KEY secret is needed here.
